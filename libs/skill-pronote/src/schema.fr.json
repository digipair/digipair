  "components": {
    "schemas": {
      "Homework": {
        "type": "object",
        "description": "Représente un devoir avec ses détails, pièces jointes et statut de completion",
        "properties": {
          "id": {
            "type": "string",
            "description": "Identifiant unique pour le devoir"
          },
          "subject": {
            "type": "string",
            "description": "La matière du devoir"
          },
          "content": {
            "type": "string",
            "description": "Le contenu ou la description du devoir en HTML"
          },
          "dueDate": {
            "type": "string",
            "format": "date",
            "description": "La date d'échéance du devoir"
          },
          "isDone": {
            "type": "boolean",
            "description": "Indique si le devoir a été terminé"
          },
          "returnFormat": {
            "type": "string",
            "enum": ["PAPER", "FILE_UPLOAD"],
            "description": "Le format dans lequel le devoir doit être rendu"
          },
          "attachments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Attachment"
            },
            "description": "Liste des pièces jointes liées au devoir"
          },
          "evaluation": {
            "type": "boolean",
            "description": "Indique si le devoir fait l'objet d'une évaluation"
          },
          "custom": {
            "type": "boolean",
            "description": "Indique si le devoir est personnalisé ou prédéfini"
          },
          "progress": {
            "type": "number",
            "description": "Pourcentage de progression de la completion du devoir"
          }
        },
        "required": ["id", "subject", "content", "dueDate", "isDone", "attachments", "evaluation", "custom"]
      },
      "News": {
        "type": "object",
        "description": "Représente un élément d'actualité de l'école avec contenu et statut d'acquittement",
        "properties": {
          "id": {
            "type": "string",
            "description": "Identifiant unique pour l'élément d'actualité"
          },
          "title": {
            "type": "string",
            "description": "Le titre de l'élément d'actualité"
          },
          "createdAt": {
            "type": "string",
            "format": "date",
            "description": "La date de création de l'élément d'actualité"
          },
          "acknowledged": {
            "type": "boolean",
            "description": "Indique si l'élément d'actualité a été acquitté par l'utilisateur"
          },
          "attachments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Attachment"
            },
            "description": "Liste des pièces jointes liées à l'élément d'actualité"
          },
          "content": {
            "type": "string",
            "description": "Le contenu ou la description de l'élément d'actualité en HTML"
          },
          "author": {
            "type": "string",
            "description": "L'auteur de l'élément d'actualité"
          },
          "category": {
            "type": "string",
            "description": "La catégorie de l'élément d'actualité"
          }
        },
        "required": ["id", "createdAt", "acknowledged", "attachments", "content", "author", "category"]
      },
      "Period": {
        "type": "object",
        "description": "Représente une période académique avec dates de début et de fin",
        "properties": {
          "name": {
            "type": "string",
            "description": "Nom de la période"
          },
          "id": {
            "type": "string",
            "description": "Identifiant unique pour la période"
          },
          "start": {
            "type": "string",
            "format": "date",
            "description": "Date de début de la période"
          },
          "end": {
            "type": "string",
            "format": "date",
            "description": "Date de fin de la période"
          }
        },
        "required": ["name", "start", "end"]
      },
      "PeriodGrades": {
        "type": "object",
        "description": "Contient toutes les notes et moyennes pour une période académique spécifique",
        "properties": {
          "studentOverall": {
            "$ref": "#/components/schemas/GradeScore",
            "description": "Moyenne générale de l'étudiant pour la période"
          },
          "classAverage": {
            "$ref": "#/components/schemas/GradeScore",
            "description": "Moyenne de classe pour la période"
          },
          "subjects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Subject"
            },
            "description": "Liste des matières avec leurs notes"
          },
          "modules": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Subject"
            },
            "description": "Liste des modules avec leurs notes"
          },
