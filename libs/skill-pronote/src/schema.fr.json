{
  "openapi": "3.0.0",
  "info": {
    "title": "@digipair/skill-pronote",
    "summary": "Intégration de la plateforme éducative Pronote",
    "description": "Cette compétence fournit des fonctions pour interagir avec la plateforme éducative Pronote, permettant l'accès aux données étudiantes, notes, devoirs, emplois du temps et plus encore.",
    "version": "0.1.0",
    "x-icon": "🎓"
  },
  "paths": {
    "/connection": {
      "post": {
        "tags": ["service"],
        "summary": "Créer une connexion Pronote",
        "parameters": [
          {
            "name": "url",
            "summary": "URL Pronote",
            "required": true,
            "description": "URL de l'instance Pronote",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "login",
            "summary": "Nom d'utilisateur",
            "required": true,
            "description": "Nom d'utilisateur ou identifiant de l'étudiant",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "password",
            "summary": "Mot de passe",
            "required": true,
            "description": "Mot de passe de l'étudiant",
            "schema": {
              "type": "string"
            }
          }
        ],
        "x-events": [],
        "responses": {
          "200": {
            "description": "Connexion Pronote établie avec succès",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "Instance Pronote pour d'autres opérations"
                }
              }
            }
          }
        }
      }
    },
