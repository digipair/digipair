  "components": {
    "schemas": {
      "Homework": {
        "type": "object",
        "description": "Represents a homework assignment with its details, attachments, and completion status",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the homework"
          },
          "subject": {
            "type": "string",
            "description": "The subject of the homework"
          },
          "content": {
            "type": "string",
            "description": "The content or description of the homework in HTML"
          },
          "dueDate": {
            "type": "string",
            "format": "date",
            "description": "The date when the homework is due"
          },
          "isDone": {
            "type": "boolean",
            "description": "Indicates whether the homework has been completed"
          },
          "returnFormat": {
            "type": "string",
            "enum": ["PAPER", "FILE_UPLOAD"],
            "description": "The format in which the homework should be returned"
          },
          "attachments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Attachment"
            },
            "description": "List of attachments related to the homework"
          },
          "evaluation": {
            "type": "boolean",
            "description": "Indicates whether the homework is subject to evaluation"
          },
          "custom": {
            "type": "boolean",
            "description": "Indicates whether the homework is custom or predefined"
          },
          "progress": {
            "type": "number",
            "description": "Progress percentage of the homework completion"
          }
        },
        "required": ["id", "subject", "content", "dueDate", "isDone", "attachments", "evaluation", "custom"]
      },
      "News": {
        "type": "object",
        "description": "Represents a news item from the school with content and acknowledgment status",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the news item"
          },
          "title": {
            "type": "string",
            "description": "The title of the news item"
          },
          "createdAt": {
            "type": "string",
            "format": "date",
            "description": "The date when the news item was created"
          },
          "acknowledged": {
            "type": "boolean",
            "description": "Indicates whether the news item has been acknowledged by the user"
          },
          "attachments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Attachment"
            },
            "description": "List of attachments related to the news item"
          },
          "content": {
            "type": "string",
            "description": "The content or description of the news item in HTML"
          },
          "author": {
            "type": "string",
            "description": "The author of the news item"
          },
          "category": {
            "type": "string",
            "description": "The category of the news item"
          }
        },
        "required": ["id", "createdAt", "acknowledged", "attachments", "content", "author", "category"]
      },
      "Period": {
        "type": "object",
        "description": "Represents an academic period with start and end dates",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the period"
          },
          "id": {
            "type": "string",
            "description": "Unique identifier for the period"
          },
          "start": {
            "type": "string",
            "format": "date",
            "description": "Start date of the period"
          },
          "end": {
            "type": "string",
            "format": "date",
            "description": "End date of the period"
          }
        },
        "required": ["name", "start", "end"]
      },
      "PeriodGrades": {
        "type": "object",
        "description": "Contains all grades and averages for a specific academic period",
        "properties": {
          "studentOverall": {
            "$ref": "#/components/schemas/GradeScore",
            "description": "Student's overall average for the period"
          },
          "classAverage": {
            "$ref": "#/components/schemas/GradeScore",
            "description": "Class average for the period"
          },
          "subjects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Subject"
            },
            "description": "List of subjects with their grades"
          },
          "modules": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Subject"
            },
            "description": "List of modules with their grades"
          },
          "rank": {
            "$ref": "#/components/schemas/GradeScore",
            "description": "Student's rank in the class"
          }
        },
        "required": ["studentOverall", "classAverage", "subjects"]
      },
      "Subject": {
        "type": "object",
        "description": "Represents a school subject with grades and averages",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the subject"
          },
          "name": {
            "type": "string",
            "description": "Name of the subject"
          },
          "studentAverage": {
            "$ref": "#/components/schemas/GradeScore",
            "description": "Student's average in this subject"
          },
          "classAverage": {
            "$ref": "#/components/schemas/GradeScore",
            "description": "Class average in this subject"
          },
          "maximum": {
            "$ref": "#/components/schemas/GradeScore",
            "description": "Maximum grade in this subject"
          },
          "minimum": {
            "$ref": "#/components/schemas/GradeScore",
            "description": "Minimum grade in this subject"
          },
          "outOf": {
            "$ref": "#/components/schemas/GradeScore",
            "description": "Total points possible in this subject"
          },
          "grades": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Grade"
            },
            "description": "Individual grades in this subject"
          },
          "credits": {
            "$ref": "#/components/schemas/GradeScore",
            "description": "Credits earned in this subject"
          },
          "rank": {
            "$ref": "#/components/schemas/GradeScore",
            "description": "Student's rank in this subject"
          }
        },
        "required": ["id", "name", "studentAverage", "classAverage", "outOf"]
      },
      "Grade": {
        "type": "object",
        "description": "Represents an individual grade with details about the assessment",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the grade"
          },
          "subjectId": {
            "type": "string",
            "description": "ID of the subject this grade belongs to"
          },
          "subjectName": {
            "type": "string",
            "description": "Name of the subject"
          },
          "description": {
            "type": "string",
            "description": "Description of the assessment"
          },
          "givenAt": {
            "type": "string",
            "format": "date",
