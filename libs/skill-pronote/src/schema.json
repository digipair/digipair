{
  "openapi": "3.0.0",
  "info": {
    "title": "@digipair/skill-pronote",
    "summary": "Pronote educational platform integration",
    "description": "This skill provides functions to interact with the Pronote educational platform, allowing access to student data, grades, homework, timetables, and more.",
    "version": "0.1.0",
    "x-icon": "🎓"
  },
  "paths": {
    "/connection": {
      "post": {
        "tags": ["service"],
        "summary": "Create Pronote connection",
        "parameters": [
          {
            "name": "url",
            "summary": "Pronote URL",
            "required": true,
            "description": "URL of the Pronote instance",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "login",
            "summary": "Username",
            "required": true,
            "description": "Student username or login",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "password",
            "summary": "Password",
            "required": true,
            "description": "Student password",
            "schema": {
              "type": "string"
            }
          }
        ],
        "x-events": [],
        "responses": {
          "200": {
            "description": "Pronote connection established successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "Pronote instance for further operations"
                }
              }
            }
          }
        }
      }
    },
