{
  "openapi": "3.0.0",
  "info": {
    "title": "@digipair/skill-worker",
    "summary": "Agent métier",
    "description": "Actions des agents métiers.",
    "version": "0.1.0",
    "x-icon": "🛠"
  },
  "paths": {
    "/activity": {
      "post": {
        "tags": ["service"],
        "summary": "Activité",
        "description": "Exécute une activité.",
        "parameters": [
          {
            "name": "name",
            "summary": "Nom",
            "required": true,
            "description": "Nom de l'activité",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "execute",
            "summary": "Execute",
            "required": true,
            "description": "Commandes à exécuter",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "https://schemas.digipair.ai/pinsSettings"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Résultat des commandes d'activité exécutées avec suivi des étapes de workflow",
            "content": {
              "application/json": {
                "schema": {
                  "description": "Résultat d'executePinsList - stocké dans context.workflow.steps[name]",
                  "additionalProperties": true
                }
              }
            }
          }
        },
        "x-events": []
      }
    },
    "/stop": {
      "post": {
        "tags": ["service"],
        "summary": "Stop",
        "description": "Stop le raisonnement",
        "parameters": [
          {
            "name": "value",
            "required": false,
            "summary": "Valeur",
            "description": "Valeur à retourner",
            "schema": {
              "type": "object"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Worker arrêté avec valeur de retour",
            "content": {
              "application/json": {
                "schema": {
                  "description": "Ne retourne jamais normalement - lève une exception DIGIPAIR_STOP"
                }
              }
            }
          }
        },
        "x-events": []
      }
    },
    "/answer": {
      "post": {
        "tags": ["service"],
        "summary": "Répondre",
        "description": "Fournit une réponse de l'agent.",
        "parameters": [
          {
            "name": "content",
            "summary": "Contenu",
            "required": true,
            "description": "Contenu de la réponse",
            "schema": {
              "type": "object",
              "additionalProperties": true
            }
          },
          {
            "name": "prompt",
            "summary": "Prompt",
            "required": false,
            "description": "Détails supplémentaires du prompt",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sources",
            "summary": "Sources",
            "required": false,
            "description": "Sources d'information utilisées pour générer la réponse",
            "schema": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true
              }
            }
          },
          {
            "name": "agent_history",
            "summary": "Historique de l'agent",
            "required": false,
            "description": "Historique des interactions de l'agent",
            "schema": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true
              }
            }
          },
          {
            "name": "files",
            "summary": "Fichiers",
            "required": false,
            "description": "Fichiers associés à la réponse",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/File"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Réponse fournie par l'agent avec contenu, détails de l'assistant, sources et historique de l'agent",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "content": {
                      "type": "object",
                      "description": "Contenu de la réponse",
                      "additionalProperties": true
                    },
                    "prompt": {
                      "type": "string",
                      "description": "Détails supplémentaires du prompt"
                    },
                    "sources": {
                      "type": "array",
                      "description": "Sources d'information utilisées pour générer la réponse",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    },
                    "agent_history": {
                      "type": "array",
                      "description": "Historique des interactions de l'agent",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    }
                  },
                  "required": ["content"]
                }
              }
            }
          }
        },
        "x-events": []
      }
    },
    "/execute": {
      "post": {
        "tags": ["service"],
        "summary": "Execute avec un contexte",
        "description": "Execute des Pin's avec un contexte donné",
        "parameters": [
          {
            "name": "execute",
            "required": true,
            "summary": "Actions à exécuter",
            "description": "Actions à exécuter",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "https://schemas.digipair.ai/pinsSettings"
              }
            }
          },
          {
            "name": "context",
            "required": false,
            "summary": "Contexte",
            "description": "Contexte d'exécution",
            "schema": {
              "type": "object"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Résultat des commandes exécutées avec le contexte donné",
            "content": {
              "application/json": {
                "schema": {
                  "description": "Résultat d'executePinsList - type dynamique basé sur les commandes exécutées",
                  "additionalProperties": true
                }
              }
            }
          }
        },
        "x-events": []
      }
    }
  },
