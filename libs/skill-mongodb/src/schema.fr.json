    "/insertOne": {
      "post": {
        "tags": ["service"],
        "summary": "Insérer un élément dans une base MongoDB",
        "parameters": [
          {
            "name": "client",
            "summary": "Connection à la base de données",
            "required": false,
            "description": "Client de connexion à la base de données",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "https://schemas.digipair.ai/pinsSettings"
              }
            }
          },
          {
            "name": "options",
            "summary": "Options",
            "required": false,
            "description": "Options d'insertion",
            "schema": {
              "type": "object"
            }
          },
          {
            "name": "collection",
            "summary": "Collection",
            "required": true,
            "description": "Nom de la collection",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "document",
            "summary": "Document",
            "required": true,
            "description": "Document à insérer",
            "schema": {
              "type": "object"
            }
          }
        ],
        "x-events": [],
        "responses": {
          "200": {
            "description": "Résultat de l'opération d'insertion",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "acknowledged": {
                      "type": "boolean",
                      "description": "Indique si l'opération a été reconnue par MongoDB"
                    },
                    "insertedId": {
                      "type": "string",
                      "description": "L'ObjectId du document inséré"
                    }
                  },
                  "required": ["acknowledged", "insertedId"]
                }
              }
            }
          }
        }
      }
    },
    "/updateOne": {
      "post": {
        "tags": ["service"],
        "summary": "Mettre à jour un élément dans une base MongoDB",
        "parameters": [
          {
            "name": "client",
            "summary": "Connection à la base de données",
            "required": false,
