            "schema": {
              "type": "object"
            }
          },
          {
            "name": "collection",
            "summary": "Collection",
            "required": true,
            "description": "Nom de la collection",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "summary": "Identifiant",
            "required": true,
