{
  "openapi": "3.0.0",
  "info": {
    "title": "@digipair/skill-mongodb",
    "summary": "Accès à une base MongoDB",
    "description": "gérer une base de données MongoDB.",
    "version": "0.1.0",
    "x-icon": "💻"
  },
  "paths": {
    "/database": {
      "post": {
        "tags": ["service"],
        "summary": "Connecter à une base MongoDB",
        "parameters": [
          {
            "name": "url",
            "summary": "Adresse du serveur",
            "required": true,
            "description": "Adresse du serveur MongoDB",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "database",
            "summary": "Base de données",
            "required": true,
            "description": "Nom de la base de données",
            "schema": {
              "type": "string"
            }
          }
        ],
        "x-events": [],
        "responses": {
          "200": {
            "description": "Connexion à la base de données établie",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "client": {
                      "type": "object",
                      "description": "Instance du client MongoDB"
                    },
                    "database": {
                      "type": "object",
                      "description": "Instance de la base de données MongoDB"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/find": {
      "post": {
        "tags": ["service"],
        "summary": "Rechercher dans une base MongoDB",
        "parameters": [
          {
            "name": "client",
            "summary": "Connection à la base de données",
            "required": false,
            "description": "Client de connexion à la base de données",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "https://schemas.digipair.ai/pinsSettings"
              }
            }
          },
          {
            "name": "options",
            "summary": "Options",
            "required": false,
            "description": "Options de recherche",
            "schema": {
              "type": "object"
            }
          },
          {
            "name": "collection",
            "summary": "Collection",
            "required": true,
            "description": "Nom de la collection",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter",
            "summary": "Filtre",
            "required": true,
            "description": "Filtre de recherche",
            "schema": {
              "type": "object"
            }
          }
        ],
        "x-events": [],
        "responses": {
          "200": {
            "description": "Tableau de documents correspondant aux critères de recherche",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "description": "Document MongoDB",
                    "properties": {
                      "_id": {
                        "type": "string",
                        "description": "Identifiant unique du document"
                      }
                    },
                    "additionalProperties": true
                  }
                }
              }
            }
          }
        }
      }
    },
    "/findOne": {
      "post": {
        "tags": ["service"],
        "summary": "Rechercher un élément dans une base MongoDB",
        "parameters": [
          {
            "name": "client",
            "summary": "Connection à la base de données",
            "required": false,
            "description": "Client de connexion à la base de données",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "https://schemas.digipair.ai/pinsSettings"
              }
            }
          },
          {
            "name": "options",
            "summary": "Options",
            "required": false,
            "description": "Options de recherche",
            "schema": {
              "type": "object"
            }
          },
          {
            "name": "collection",
            "summary": "Collection",
            "required": true,
            "description": "Nom de la collection",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter",
            "summary": "Filtre",
            "required": true,
            "description": "Filtre de recherche",
            "schema": {
              "type": "object"
            }
          }
        ],
        "x-events": [],
        "responses": {
          "200": {
            "description": "Document unique correspondant aux critères de recherche, ou null si non trouvé",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "description": "Document MongoDB",
                      "properties": {
                        "_id": {
                          "type": "string",
                          "description": "Identifiant unique du document"
                        }
                      },
                      "additionalProperties": true
                    },
                    {
                      "type": "null",
                      "description": "Aucun document trouvé"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
