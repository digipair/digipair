            "schema": {
              "type": "number"
            }
          },
          {
            "name": "filter",
            "summary": "Filtres",
            "required": false,
            "description": "Filtres de recherche",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "language",
            "summary": "Langue",
            "required": true,
            "description": "Langue de recherche",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "query",
            "summary": "Texte à rechercher",
            "required": true,
